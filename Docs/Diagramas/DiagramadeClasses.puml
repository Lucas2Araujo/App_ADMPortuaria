@startuml
title Modelo de Domínio: Administração Portuária (v3)
skinparam classAttributeIconSize 0
enum StatusNavio {
  PENDENTE
  VALIDADO
  REJEITADO
  ATRACADO
  FINALIZADO
}

enum StatusVaga {
  LIVRE
  OCUPADA
}

class Navio {
- imoID: String
  - nome: String
  - comandante: String
  - status: StatusNavio
  - dataSolicitacao: DateTime
  + solicitarPreCadastro()
  + validarDescarga(resultado: StatusNavio)
}

class Carga {
  - idCarga: Integer
  - descricao: String
  - quantidadeToneladas: Double
  - ehPerecivel: Boolean
  - statusAlfandega: String
  - documentosAnexos: String
  + solicitarLiberacaoAduaneira()
}

class Vaga {
  - idVaga: Integer
  - status: StatusVaga
  + atualizarStatus(novoStatus: StatusVaga)
  + verificarDisponibilidade(): Boolean
}

class FilaAtracacao {
  - idFila: Integer
  - dataHoraEntrada: DateTime
  - dataHoraSaida: DateTime
  - nivelPrioridade: Integer
  + calcularPrioridade(carga: Carga)
  + chamarProximoNavio(): Navio
}

class Atracacao {
  - dataHoraInicio: DateTime
  - dataHoraFim: DateTime
  + calcularTempoTotal()
  + finalizarAtracacao()
}

' Relacionamentos
Navio "1" *-- "1..*" Carga : transporta >
Navio "0..*" -- "1" Vaga : ocupa >
(Navio, Vaga) .. Atracacao
Navio "1" -- "0..1" FilaAtracacao : aguarda em >

@enduml