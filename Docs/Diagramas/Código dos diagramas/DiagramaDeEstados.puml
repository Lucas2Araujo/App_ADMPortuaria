@startuml
title Diagrama de Estados: Estados do Navio

skinparam state {
    RoundCorner 20
    BackgroundColor White
    }

state Navio
state "Pré-cadastrado" as PreCadastrado
state "Aguardando documentação" as AguardandoDoc
state "Cadastro concluído" as CadastroConcluido
state "Navio liberado" as NavioLiberado

[*] --> Navio

Navio --> PreCadastrado : Solicitar cadastro()

PreCadastrado --> AguardandoDoc : Solicitar documentação()

AguardandoDoc --> Aprovado : Documentação aprovada
AguardandoDoc --> Reprovado : Documentação reprovada

Reprovado --> [*]

Aprovado --> CadastroConcluido

CadastroConcluido --> Cadastrado : Enviar cadastro()

Cadastrado --> Fila : Calcular prioridade()

Fila --> Atracado : Atracar()

Atracado --> NavioLiberado : Liberar navio()

NavioLiberado --> [*]

@enduml
